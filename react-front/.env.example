# Desenvolvimento local — chamadas diretas ao Django (next dev injeta no bundle)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Railway — no serviço **Next**, o proxy lê em runtime:
# NEXT_PUBLIC_API_URL=https://eventix-development.up.railway.app
# ou (prioritário) EVENTIX_API_URL=https://… ou URL da rede privada do Django.
#
# Se o proxy devolver 502 "contactar o backend": entre serviços Railway use o URL
# **privado** do Django em EVENTIX_API_URL (Networking no painel do Django).
# Depuração: EVENTIX_PROXY_DEBUG=1 (mostra mensagem técnica na resposta JSON).
#
# Só em casos avançados: chamada direta browser→Django em produção (exige URL
# no build + CORS). NEXT_PUBLIC_API_DIRECT=true
#
# Opcional no backend (Django): CORS_ALLOWED_ORIGINS_EXTRA, CSRF_TRUSTED_ORIGINS_EXTRA
