# Opção A — desenvolvimento local: chamadas diretas ao Django
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Opção B — Railway / produção (recomendado): sem NEXT_PUBLIC_API_URL o browser
# usa o proxy same-origin /api/eventix/... . Defina só no servidor Next:
# EVENTIX_API_URL=https://seu-backend-django.up.railway.app
#
# Se preferir URL direta no cliente (tem de estar presente no *build* do Next):
# NEXT_PUBLIC_API_URL=https://seu-backend-django.up.railway.app
# Não use http:// na URL pública se o front for https (o browser bloqueia).
# Não use *.railway.internal no NEXT_PUBLIC_* (só funciona dentro do Railway).
#
# Se "já está configurado" mas dá Failed to fetch: (1) redeploy do Next após
# mudar NEXT_PUBLIC_*; ou (2) NEXT_PUBLIC_API_VIA_PROXY=true e só EVENTIX_API_URL.
# NEXT_PUBLIC_API_VIA_PROXY=true
#
# Opcional no backend (Django): CORS_ALLOWED_ORIGINS_EXTRA, CSRF_TRUSTED_ORIGINS_EXTRA
